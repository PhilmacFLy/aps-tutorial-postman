		{
			"name": "Task 3 - Upload AppBundle",
			"item": [
				{
					"name": "Register the AppBundle",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"var body = JSON.parse(responseBody);",
									"pm.collectionVariables.set(\"dasAppBundleId\",body[\"id\"]);",
									"pm.collectionVariables.set(\"MyFirstFusionAppBundleUrl\", body[\"uploadParameters\"][\"endpointURL\"]);",
									"pm.collectionVariables.set(\"MyFirstFusionAppBundleVersion\", body[\"version\"]);",
									"pm.collectionVariables.set(\"MyFirstFusionAppBundleFormDataKey\", body[\"uploadParameters\"][\"formData\"][\"key\"]);",
									"pm.collectionVariables.set(\"MyFirstFusionAppBundleFormDataPolicy\", body[\"uploadParameters\"][\"formData\"][\"policy\"]);",
									"pm.collectionVariables.set(\"MyFirstFusionAppBundleFormDataSignature\", body[\"uploadParameters\"][\"formData\"][\"x-amz-signature\"]);",
									"pm.collectionVariables.set(\"MyFirstFusionAppBundleFormDataCredential\", body[\"uploadParameters\"][\"formData\"][\"x-amz-credential\"]);",
									"pm.collectionVariables.set(\"MyFirstFusionAppBundleFormDataDate\", body[\"uploadParameters\"][\"formData\"][\"x-amz-date\"]);",
									"pm.collectionVariables.set(\"MyFirstFusionAppBundleFormDataToken\", body[\"uploadParameters\"][\"formData\"][\"x-amz-security-token\"]);",
									"pm.collectionVariables.set(\"MyFirstFusionAppBundleFormRedirect\", body[\"uploadParameters\"][\"formData\"][\"success_action_redirect\"]);"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Authorization",
								"value": "Bearer {{dasApiToken}}",
								"type": "text"
							},
							{
								"key": "Content-Type",
								"value": "application/json",
								"type": "text"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"id\": \"MyFirstFusionAppBundle\",\n  \"engine\": \"Autodesk.Fusion+24\",\n  \"description\": \"Change MyFirstFusionAppBundle based on Fusion 2024\"\n}"
						},
						"url": {
							"raw": "https://developer.api.autodesk.com/da/us-east/v3/appbundles",
							"protocol": "https",
							"host": [
								"developer",
								"api",
								"autodesk",
								"com"
							],
							"path": [
								"da",
								"us-east",
								"v3",
								"appbundles"
							]
						},
						"description": "[See documentation](https://aps.autodesk.com/en/docs/design-automation/v3/reference/http/appbundles-POST/)"
					},
					"response": []
				},
				{
					"name": "Upload the AppBundle",
					"event": [
						{
							"listen": "prerequest",
							"script": {
								"exec": [
									""
								],
								"type": "text/javascript"
							}
						},
						{
							"listen": "test",
							"script": {
								"exec": [
									""
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [],
						"body": {
							"mode": "formdata",
							"formdata": [
								{
									"key": "key",
									"value": "{{MyFirstFusionAppBundleFormDataKey}}",
									"type": "text"
								},
								{
									"key": "content-type",
									"value": "application/octet-stream",
									"type": "text"
								},
								{
									"key": "policy",
									"value": "{{MyFirstFusionAppBundleFormDataPolicy}}",
									"type": "text"
								},
								{
									"key": "success_action_status",
									"value": "200",
									"type": "text"
								},
								{
									"key": "x-amz-signature",
									"value": "{{MyFirstFusionAppBundleFormDataSignature}}",
									"type": "text"
								},
								{
									"key": "x-amz-credential",
									"value": "{{MyFirstFusionAppBundleFormDataCredential}}",
									"type": "text"
								},
								{
									"key": "x-amz-algorithm",
									"value": "AWS4-HMAC-SHA256",
									"type": "text"
								},
								{
									"key": "x-amz-date",
									"value": "{{MyFirstFusionAppBundleFormDataDate}}",
									"type": "text"
								},
								{
									"key": "x-amz-server-side-encryption",
									"value": "AES256",
									"type": "text"
								},
								{
									"key": "x-amz-security-token",
									"value": "{{MyFirstFusionAppBundleFormDataToken}}",
									"type": "text"
								},
								{
									"key": "success_action_redirect",
									"value": "{{MyFirstFusionAppBundleFormRedirect}}",
									"type": "text"
								},
								{
									"key": "file",
									"type": "file",
									"src": []
								}
							]
						},
						"url": {
							"raw": "{{MyFirstFusionAppBundleUrl}}",
							"host": [
								"{{MyFirstFusionAppBundleUrl}}"
							]
						},
						"description": "This request to the Design Automation API uploads an AppBundle to APS.\n\n&nbsp;\n\nBefore you send this request: \n\n  1. Download the file *helloFusion.zip* from the [*walkthrough_data* folder of the repository that contained this Postman Collection](https://github.com/philmacfly/aps-tutorial-postman/tree/master/DA4Fusion/walkthrough_data).\n  2. Go to the **Body** tab below.\n  3. Scroll down so that the **File** row is visible.\n  4. Click **Select** and pick *helloFusion.zip*, which you downloaded in step 1."
					},
					"response": []
				},
